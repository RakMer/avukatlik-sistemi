# Env file configuration template for Avukatlik Sistemi

# Database Configurations
DB_USER=postgres
DB_PASSWORD=postgres_secure_password
DB_NAME=avukat_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# Redis Configuration
REDIS_URL=redis://redis:6379

# n8n Configurations
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=some_random_secure_encryption_key
WEBHOOK_URL=http://localhost:5678

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Cloud Storage (GCS) Backup Configurations
GCS_BUCKET=your_gcs_bucket_name_here
# Note: Google Service Account key should be placed at secrets/gcs-key.json
