# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc coverage directory
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-temporary-files)
.grunt

# Bower dependency directory (http://bower.io/)
bower_components

# node-gyp's build directory
build/Release

# Dependency directories
node_modules/
jspm_packages/

# TypeScript v1.x command line compiler build cache
tsconfig.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Secrets and keys
/secrets/*
!/secrets/.gitkeep

# Docker volumes / local data directories
/pgdata/
/n8ndata/
/backup_data/

# OS files
.DS_Store
Thumbs.db
